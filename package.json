{
  "name": "@justfortytwo/gate",
  "version": "0.1.1",
  "description": "Standalone, agent-agnostic PreToolUse safety gate for Claude Code: an autonomy-tier policy engine, a fail-closed bash allowlist, and a hook that turns dangerous tool calls into one-shot approvals.",
  "license": "MIT",
  "author": {
    "name": "Enrico Deleo",
    "url": "https://enricodeleo.com"
  },
  "homepage": "https://forty-two.it",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justfortytwo/gate.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gate-hook": "./dist/gate-hook.js"
  },
  "bin": {
    "fortytwo-gate-hook": "./dist/gate-hook.js",
    "fortytwo-gate": "./dist/cli-bin.js"
  },
  "files": [
    "dist",
    "hooks",
    ".claude-plugin",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "pretooluse",
    "hook",
    "safety",
    "policy",
    "allowlist",
    "agent",
    "guardrail"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
